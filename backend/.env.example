# URL de conexión a PostgreSQL (Railway la provee automáticamente en producción)
DATABASE_URL=postgresql://user:password@localhost:5432/comandia

# Secreto usado para firmar los tokens JWT
JWT_SECRET=change_this_secret_in_production

# Puerto en el que corre el servidor Express
PORT=3000

# Entorno de ejecución: development | production
NODE_ENV=development

# Zona horaria del proceso de Node (afecta cálculos de fecha/hora del servidor)
TZ=America/Bogota

# API key de Resend (https://resend.com) para el envío de emails transaccionales
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pública del frontend, usada en los links de los emails (verificación, reset)
APP_URL=http://localhost:5173

# Credenciales de Mercado Pago (https://www.mercadopago.com.co/developers/panel)
# usadas para consultar pagos/suscripciones desde el backend (webhook y verificación)
MP_ACCESS_TOKEN=tu_access_token_de_mercado_pago
MP_CLIENT_ID=tu_client_id
